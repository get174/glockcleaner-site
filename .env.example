# Environment variables for GlockCleaner site
# Copy to .env and fill with your values
# Never commit .env!

# Supabase (get from https://supabase.com/dashboard/project/_/settings/api)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# Flutterwave (get from https://dashboard.flutterwave.com/)
VITE_FLUTTERWAVE_CLIENT_ID=your-client-id
VITE_FLUTTERWAVE_PUBLIC_KEY=your-public-key
VITE_FLUTTERWAVE_ENCRYPTION_KEY=your-encryption-key

# For production: Use your PROD Supabase project URL/key!
# Dev: Use dev project

